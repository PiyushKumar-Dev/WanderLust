<% layout("/layout/boilerplate") %>

<body>
    <h1>All Listings</h1>
    <div class="row  row-cols-lg-3  row-cols-md-2 row-cols-sm-1"> 
      <% for(let list of allListing){%>
        <a href="/listings/<%=list._id%>" class="list-link ">
    <div class="card col listing-card">
  <img class="card-img-top" src="<%=list.image.url%>" alt="Card image cap" style="height:20rem"/>
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text"><b><%=list.title%></b>
    <br/>
     <%=(list.price||0).toLocaleString("en-IN")%>/night
  </p>
  </div>
</div> 
</a > 
<% }%> 
    </div>

</body>
