# Port the application will run on inside the container / server
PORT=8080

# Environment mode (production, development, test)
NODE_ENV=production

# MongoDB Connection String (Atlas URL or Docker Container service URL)
# Example for Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/wanderlust?retryWrites=true&w=majority
# Example for local development: mongodb://127.0.0.1:27017/wanderlust
MONGO_URL=mongodb://127.0.0.1:27017/wanderlust

# Secret key used for signing express session cookies (Use a long random string in production)
SESSION_SECRET=your_production_session_secret_key_here
